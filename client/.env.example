# ─── Senger Market Terminal — Client Environment ────────────────────────────
# Copy this file to .env (or .env.local) and fill in the values.
# All VITE_* variables are inlined at build time — never put secrets here.

# ─── Required in production ───────────────────────────────────────────────────
# API server URL (required in production)
VITE_API_URL=https://your-backend-url.onrender.com

# WebSocket URL (required in production)
VITE_WS_URL=wss://your-backend-url.onrender.com/ws

# ─── Development defaults ─────────────────────────────────────────────────────
# For local development with backend on same host:
#   VITE_API_URL=http://localhost:3001
#   VITE_WS_URL=ws://localhost:3001/ws

# ─── Apple Sign In (optional) ────────────────────────────────────────────────
VITE_APPLE_CLIENT_ID=com.your.app.id
VITE_APPLE_REDIRECT_URI=https://your-frontend-url.onrender.com
