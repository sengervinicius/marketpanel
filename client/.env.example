# ─── Senger Market Terminal — Client Environment ────────────────────────────
# Copy this file to .env (or .env.local) and fill in the values.
# All VITE_* variables are inlined at build time — never put secrets here.

# Base URL of the Express server (no trailing slash).
# Leave empty to use relative paths (same origin — works when client & server
# are served together via a reverse proxy or the server's static middleware).
VITE_API_URL=

# WebSocket endpoint of the server.
# Must start with ws:// or wss:// — cannot be left empty.
VITE_WS_URL=ws://localhost:3001/ws

# ─── Example overrides for different environments ───────────────────────────
# Local development (default):
#   VITE_API_URL=http://localhost:3001
#   VITE_WS_URL=ws://localhost:3001/ws
#
# Production (HTTPS + WSS):
#   VITE_API_URL=https://api.yourdomain.com
#   VITE_WS_URL=wss://api.yourdomain.com/ws
