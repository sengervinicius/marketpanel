# ─── Senger Market Terminal — Server Configuration ────────────────────────────
# Copy this file to .env and fill in the values for your environment

# ─── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
POLYGON_API_KEY=your-polygon-api-key

# ─── Required in production ───────────────────────────────────────────────────
CLIENT_URL=https://your-frontend-url.onrender.com
NODE_ENV=production

# ─── MongoDB (optional in dev, recommended for production) ────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=senger

# ─── Stripe billing (optional) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...            # Monthly subscription price ID
STRIPE_ANNUAL_PRICE_ID=price_...     # Annual subscription price ID (optional)

# ─── Apple Sign In (optional) ─────────────────────────────────────────────────
APPLE_CLIENT_ID=com.arccapital.senger

# ─── Apple IAP (optional) ─────────────────────────────────────────────────────
APPLE_IAP_SHARED_SECRET=your_shared_secret_from_app_store_connect

# ─── Twelve Data (optional, for international equities) ─────────────────────
TWELVEDATA_API_KEY=your_twelvedata_api_key

# ─── Eulerpool (optional, for bonds/fixed income/options) ────────────────────
EULERPOOL_API_KEY=your_eulerpool_api_key

# ─── Seed users (optional, format: user1:pass1,user2:pass2) ──────────────────
SEED_USERS=

# ─── Development defaults (ignored in production) ────────────────────────────
PORT=3001
