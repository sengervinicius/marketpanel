# ─── Particle Market Terminal — Server Configuration ──────────────────────────
# Copy this file to .env and fill in the values for your environment

# ─── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
POLYGON_API_KEY=your-polygon-api-key

# ─── Required in production ───────────────────────────────────────────────────
CLIENT_URL=https://your-frontend-url.onrender.com
NODE_ENV=production

# ─── Postgres (required for production) ──────────────────────────────────────
POSTGRES_URL=postgres://user:pass@host:5432/dbname

# ─── Market Data Providers ───────────────────────────────────────────────────
TWELVEDATA_API_KEY=your_twelvedata_api_key
EULERPOOL_API_KEY=your_eulerpool_api_key
FRED_API_KEY=your_fred_api_key          # Optional — falls back to public CSV

# ─── AI Providers ──────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key      # Used for vault embeddings

# ─── Stripe billing ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Legacy single-price (backward compat):
STRIPE_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# Tier-specific prices (New Particle / Dark Particle / Nuclear Particle):
STRIPE_NEW_PARTICLE_MONTHLY=price_...
STRIPE_NEW_PARTICLE_ANNUAL=price_...
STRIPE_DARK_PARTICLE_MONTHLY=price_...
STRIPE_DARK_PARTICLE_ANNUAL=price_...
STRIPE_NUCLEAR_PARTICLE_MONTHLY=price_...
STRIPE_NUCLEAR_PARTICLE_ANNUAL=price_...

# ─── Apple Sign In / IAP (optional) ─────────────────────────────────────────
APPLE_CLIENT_ID=com.particle.market
APPLE_IAP_SHARED_SECRET=your_shared_secret_from_app_store_connect

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_USER_IDS=1                        # Comma-separated user IDs with admin access

# ─── Seed users (optional, format: user1:pass1,user2:pass2) ──────────────────
SEED_USERS=

# ─── Development defaults (ignored in production) ────────────────────────────
PORT=3001
