# ─── Particle Market Terminal — Server Configuration ──────────────────────────
# Copy this file to .env and fill in the values for your environment

# ─── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
POLYGON_API_KEY=your-polygon-api-key

# ─── Required in production ───────────────────────────────────────────────────
CLIENT_URL=https://your-frontend-url.onrender.com
NODE_ENV=production

# ─── Postgres (required for production) ──────────────────────────────────────
POSTGRES_URL=postgres://user:pass@host:5432/dbname

# ─── Market Data Providers ───────────────────────────────────────────────────
TWELVEDATA_API_KEY=your_twelvedata_api_key
EULERPOOL_API_KEY=your_eulerpool_api_key
FRED_API_KEY=your_fred_api_key          # Optional — falls back to public CSV
FINNHUB_API_KEY=your_finnhub_api_key    # Optional — earnings calendar integration

# ─── AI Providers ──────────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key      # Used for vault embeddings

# ─── Stripe billing ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Legacy single-price (backward compat):
STRIPE_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# Tier-specific prices (New Particle / Dark Particle / Nuclear Particle):
STRIPE_NEW_PARTICLE_MONTHLY=price_...
STRIPE_NEW_PARTICLE_ANNUAL=price_...
STRIPE_DARK_PARTICLE_MONTHLY=price_...
STRIPE_DARK_PARTICLE_ANNUAL=price_...
STRIPE_NUCLEAR_PARTICLE_MONTHLY=price_...
STRIPE_NUCLEAR_PARTICLE_ANNUAL=price_...

# ─── Apple Sign In / IAP (optional) ─────────────────────────────────────────
APPLE_CLIENT_ID=com.particle.market
APPLE_IAP_SHARED_SECRET=your_shared_secret_from_app_store_connect

# ─── Email (Resend — W3.3) ────────────────────────────────────────────────
# Resend is the primary transactional provider. DNS lives on Cloudflare.
# If RESEND_API_KEY is unset, emailService falls back to the SMTP vars below.
RESEND_API_KEY=re_...
EMAIL_FROM_HELLO=hello@the-particle.com          # Welcome / onboarding
EMAIL_FROM_RECEIPTS=receipts@the-particle.com    # Stripe / IAP receipts
EMAIL_FROM_NOTIFICATIONS=notifications@the-particle.com  # Alerts / dunning

# ─── Email (SMTP fallback) ────────────────────────────────────────────────
EMAIL_SMTP_HOST=                        # e.g. smtp.sendgrid.net (optional)
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=                             # Legacy fallback FROM (backward compat)

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_USER_IDS=1                        # Comma-separated user IDs with admin access
ADMIN_EMAILS=                           # Comma-separated admin emails (preferred; stable across envs)

# ─── Inbound email → Central Vault (P3.1) ────────────────────────────────────
# Postmark posts inbound JSON to /api/inbound/email/<INBOUND_EMAIL_WEBHOOK_SECRET>.
# The secret is part of the URL path — choose a 32+ char random string and
# paste the full URL (with token) into the Postmark server's Inbound Webhook.
# See docs/OPS_INBOUND_EMAIL.md for the Cloudflare DNS + Postmark setup.
INBOUND_EMAIL_WEBHOOK_SECRET=           # e.g. a 32-char urlsafe random token

# Comma-separated email addresses that are allowed to ingest into the
# central vault. Anything from outside this list is dropped with an
# audit log line — this is the main defence against prompt-injection
# payloads mailed to vault@the-particle.com by an attacker.
VAULT_INBOUND_ALLOWED_SENDERS=          # e.g. founder@the-particle.com,vinicius@arccapital.com.br

# ─── Seed users (optional, format: user1:pass1,user2:pass2) ──────────────────
SEED_USERS=

# ─── Development defaults (ignored in production) ────────────────────────────
PORT=3001
